{
  "name": "mumu-bot-admin-assets",
  "private": true,
  "scripts": {
    "build": "npm run build:css && npm run build:js",
    "build:css": "tailwindcss -i ./internal/web/assets/src/admin.css -o ./internal/web/assets/dist/admin.css --minify",
    "build:js": "esbuild ./internal/web/assets/src/admin.js --bundle --format=iife --target=es2020 --minify --outfile=./internal/web/assets/dist/admin.js"
  },
  "devDependencies": {
    "@tailwindcss/cli": "4.2.2",
    "@tailwindcss/forms": "0.5.11",
    "alpinejs": "3.15.9",
    "esbuild": "0.27.4",
    "htmx.org": "2.0.8",
    "preline": "4.1.3",
    "tailwindcss": "4.2.2"
  }
}
