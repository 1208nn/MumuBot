package views

import "fmt"

templ TopicListPage(data TopicListPageData, currentPath string) {
	@Layout(LayoutData{
		Title:       "话题",
		CurrentPath: currentPath,
		NavItems:    NavItems(),
		Flash:       data.Flash,
	}, TopicListBody(data))
}

templ TopicListBody(data TopicListPageData) {
	<div class="space-y-6">
		@PageHeader("话题", "查看每个群里正在进行或已经归档的话题摘要，快速回看脉络和未完事项。", "话题工作记忆")
		<div class="space-y-4 rounded-[1.7rem] border border-white/70 bg-white/82 p-4 shadow-[0_22px_60px_rgba(14,31,53,0.08)] backdrop-blur-xl motion-safe:animate-[admin-fade-up_220ms_ease-out] sm:p-5">
			@FilterPanel("topic-filters", "筛选条件", "按群号、状态或关键词查找当前话题与归档话题。", EmptyComponent(), false, TopicFilterForm(data))
			@SortToolbar(data.Sort)
			<div class="grid gap-4 xl:grid-cols-2">
				if len(data.Items) == 0 {
					<div class="rounded-[1.75rem] border border-dashed border-slate-300/80 bg-white/55 p-6 text-center text-sm font-medium text-slate-500 xl:col-span-2">暂无话题记录</div>
				}
				for _, item := range data.Items {
					<a href={ fmt.Sprintf("/admin/topics/%d", item.ID) } class="group rounded-[1.5rem] border border-slate-200/75 bg-white/80 p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.82)] transition duration-200 ease-out hover:-translate-y-0.5 hover:border-cyan-200 hover:shadow-[0_20px_50px_rgba(14,31,53,0.08)] motion-safe:animate-[admin-fade-up_220ms_ease-out]">
						<div class="flex flex-wrap items-start justify-between gap-3">
							<div class="min-w-0">
								<div class="text-xs font-extrabold uppercase tracking-[0.12em] text-slate-500">群 { fmt.Sprintf("%d", item.GroupID) }</div>
								<h2 class="mt-2 text-[1.12rem] font-extrabold tracking-[-0.04em] text-slate-950">{ topicTitle(item) }</h2>
							</div>
							<div class="flex flex-wrap items-center gap-2">
								<span class={ topicStatusClass(item.Status) }>{ topicStatusText(item.Status) }</span>
								<span class={ topicSummaryProgressClass(item) }>{ topicSummaryProgressText(item) }</span>
							</div>
						</div>
						<p class="mt-4 text-sm leading-7 text-slate-600">{ topicGist(item) }</p>
						<div class="mt-5 grid gap-3 sm:grid-cols-3">
							<div class="rounded-[1.1rem] bg-slate-50/90 px-3 py-3 ring-1 ring-slate-200/80">
								<div class="text-[11px] font-extrabold uppercase tracking-[0.12em] text-slate-500">最近消息</div>
								<div class="mt-1 text-sm font-semibold text-slate-900">#{ fmt.Sprintf("%d", item.LastMessageLogID) }</div>
							</div>
							<div class="rounded-[1.1rem] bg-slate-50/90 px-3 py-3 ring-1 ring-slate-200/80">
								<div class="text-[11px] font-extrabold uppercase tracking-[0.12em] text-slate-500">摘要覆盖</div>
								<div class="mt-1 text-sm font-semibold text-slate-900">#{ fmt.Sprintf("%d", item.SummaryUntilMessageLogID) }</div>
							</div>
							<div class="rounded-[1.1rem] bg-slate-50/90 px-3 py-3 ring-1 ring-slate-200/80">
								<div class="text-[11px] font-extrabold uppercase tracking-[0.12em] text-slate-500">最近更新</div>
								<div class="mt-1 text-sm font-semibold text-slate-900">{ formatTime(item.UpdatedAt) }</div>
							</div>
						</div>
						if len(topicKeywords(item)) > 0 {
							<div class="mt-4 flex flex-wrap gap-2">
								for _, keyword := range topicKeywords(item) {
									<span class="inline-flex items-center rounded-full bg-cyan-50 px-3 py-1 text-[11px] font-semibold text-cyan-700 ring-1 ring-cyan-200/80">{ keyword }</span>
								}
							</div>
						}
						if topicParticipantSummary(item) != "" {
							<div class="mt-4 rounded-[1.15rem] bg-slate-50/90 px-4 py-3 text-sm leading-6 text-slate-600 ring-1 ring-slate-200/80">
								<span class="font-semibold text-slate-800">话题里的角色关系：</span>{ topicParticipantSummary(item) }
							</div>
						}
						<div class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-cyan-700">
							<span>查看详情</span>
							<svg class="size-4 transition duration-200 ease-out group-hover:translate-x-0.5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M6 10h8"></path>
								<path d="m11 5 5 5-5 5"></path>
							</svg>
						</div>
					</a>
				}
			</div>
			@ListFooter(data.Meta)
		</div>
	</div>
}

templ TopicFilterForm(data TopicListPageData) {
	<form id="topic-filter-form" class="space-y-3" method="get" action="/admin/topics" hx-get="/admin/topics" hx-trigger="change from:input[type='radio'], submit" hx-target="#admin-page-body" hx-swap="outerHTML" hx-push-url="true">
		@ChoiceFilterGroup("status", data.Status, []FilterChoice{
			{Label: "全部状态", Value: ""},
			{Label: "进行中", Value: "active"},
			{Label: "已归档", Value: "archived"},
		})
		<div class="grid gap-2.5 xl:grid-cols-[minmax(0,10rem)_minmax(0,1fr)_auto] xl:items-center">
			<input type="hidden" name="sort" value={ data.Sort.CurrentSort }/>
			<input type="hidden" name="order" value={ data.Sort.CurrentOrder }/>
			<input class="block w-full min-w-0 rounded-2xl border-slate-200/80 bg-white/90 px-4 py-2.5 text-sm text-slate-800 shadow-none placeholder:text-slate-400 focus:border-cyan-300 focus:ring-4 focus:ring-cyan-100" type="text" name="group_id" value={ data.GroupID } placeholder="群号"/>
			<input class="block w-full min-w-0 rounded-2xl border-slate-200/80 bg-white/90 px-4 py-2.5 text-sm text-slate-800 shadow-none placeholder:text-slate-400 focus:border-cyan-300 focus:ring-4 focus:ring-cyan-100" type="text" name="keyword" value={ data.Keyword } placeholder="关键词、标题或摘要"/>
			<button class="inline-flex items-center justify-center gap-2 rounded-2xl bg-[linear-gradient(135deg,#101a32_0%,#1e2c4f_58%,#0b7285_120%)] px-4 py-2.5 text-sm font-semibold text-white shadow-[0_18px_32px_rgba(15,23,42,0.16)] transition duration-200 ease-out hover:brightness-105 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-300 focus-visible:ring-offset-2 focus-visible:ring-offset-white disabled:cursor-wait disabled:opacity-70 xl:min-w-28" type="submit" data-loading-label="筛选中">筛选</button>
		</div>
	</form>
}

templ TopicDetailPage(data TopicDetailPageData, currentPath string) {
	@Layout(LayoutData{
		Title:       topicTitle(data.Thread),
		CurrentPath: currentPath,
		NavItems:    NavItems(),
		Flash:       data.Flash,
	}, TopicDetailBody(data))
}

templ TopicDetailBody(data TopicDetailPageData) {
	<div class="space-y-6">
		<div class="flex flex-wrap items-start justify-between gap-4">
			@PageHeader(topicTitle(data.Thread), "回看这个话题当前的概括、最近变化和关联消息。", "话题详情")
			<a href="/admin/topics" class="inline-flex items-center justify-center gap-2 rounded-2xl border border-slate-200/80 bg-white/82 px-4 py-3 text-sm font-semibold text-slate-700 shadow-[inset_0_1px_0_rgba(255,255,255,0.85)] transition duration-200 ease-out hover:bg-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-300 focus-visible:ring-offset-2 focus-visible:ring-offset-white">返回话题列表</a>
		</div>
		<div class="grid gap-4 xl:grid-cols-[minmax(0,1.2fr)_minmax(22rem,0.8fr)]">
			<section class="space-y-4 rounded-[1.7rem] border border-white/70 bg-white/82 p-5 shadow-[0_22px_60px_rgba(14,31,53,0.08)] backdrop-blur-xl motion-safe:animate-[admin-fade-up_220ms_ease-out]">
				<div class="flex flex-wrap items-center gap-2">
					<span class={ topicStatusClass(data.Thread.Status) }>{ topicStatusText(data.Thread.Status) }</span>
					<span class={ topicSummaryProgressClass(data.Thread) }>{ topicSummaryProgressText(data.Thread) }</span>
					<span class="inline-flex items-center rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600 ring-1 ring-slate-200">群 { fmt.Sprintf("%d", data.Thread.GroupID) }</span>
				</div>
				<div class="rounded-[1.35rem] bg-slate-50/90 p-5 ring-1 ring-slate-200/80">
					<div class="text-xs font-extrabold uppercase tracking-[0.12em] text-slate-500">当前概括</div>
					<div class="mt-3 text-[1.02rem] font-bold tracking-[-0.03em] text-slate-950">{ topicGist(data.Thread) }</div>
					if len(topicSummary(data.Thread).Facts) > 0 {
						<div class="mt-4 text-xs font-extrabold uppercase tracking-[0.12em] text-slate-500">已确认的信息</div>
						<ul class="mt-2 space-y-2 text-sm leading-6 text-slate-700">
							for _, fact := range topicSummary(data.Thread).Facts {
								<li class="flex gap-2">
									<span class="mt-[0.38rem] inline-flex size-1.5 shrink-0 rounded-full bg-cyan-500"></span>
									<span>{ fact }</span>
								</li>
							}
						</ul>
					}
					if len(topicSummary(data.Thread).OpenLoops) > 0 {
						<div class="mt-4 text-xs font-extrabold uppercase tracking-[0.12em] text-slate-500">还没聊完的点</div>
						<ul class="mt-2 space-y-2 text-sm leading-6 text-slate-700">
							for _, loop := range topicSummary(data.Thread).OpenLoops {
								<li class="flex gap-2">
									<span class="mt-[0.38rem] inline-flex size-1.5 shrink-0 rounded-full bg-amber-500"></span>
									<span>{ loop }</span>
								</li>
							}
						</ul>
					}
				</div>
				if topicParticipantSummary(data.Thread) != "" {
					<div class="rounded-[1.25rem] bg-white/82 p-4 ring-1 ring-slate-200/80">
						<div class="text-xs font-extrabold uppercase tracking-[0.12em] text-slate-500">参与者视角</div>
						<div class="mt-2 text-sm leading-7 text-slate-700">{ topicParticipantSummary(data.Thread) }</div>
					</div>
				}
				if len(topicKeywords(data.Thread)) > 0 {
					<div class="flex flex-wrap gap-2">
						for _, keyword := range topicKeywords(data.Thread) {
							<span class="inline-flex items-center rounded-full bg-cyan-50 px-3 py-1 text-[11px] font-semibold text-cyan-700 ring-1 ring-cyan-200/80">{ keyword }</span>
						}
					</div>
				}
			</section>
			<section class="space-y-4 rounded-[1.7rem] border border-white/70 bg-white/82 p-5 shadow-[0_22px_60px_rgba(14,31,53,0.08)] backdrop-blur-xl motion-safe:animate-[admin-fade-up_220ms_ease-out]">
				<div class="grid gap-3 sm:grid-cols-2">
					<div class="rounded-[1.15rem] bg-slate-50/90 px-4 py-4 ring-1 ring-slate-200/80">
						<div class="text-[11px] font-extrabold uppercase tracking-[0.12em] text-slate-500">最近消息编号</div>
						<div class="mt-2 text-sm font-semibold text-slate-900">#{ fmt.Sprintf("%d", data.Thread.LastMessageLogID) }</div>
					</div>
					<div class="rounded-[1.15rem] bg-slate-50/90 px-4 py-4 ring-1 ring-slate-200/80">
						<div class="text-[11px] font-extrabold uppercase tracking-[0.12em] text-slate-500">摘要覆盖到</div>
						<div class="mt-2 text-sm font-semibold text-slate-900">#{ fmt.Sprintf("%d", data.Thread.SummaryUntilMessageLogID) }</div>
					</div>
					<div class="rounded-[1.15rem] bg-slate-50/90 px-4 py-4 ring-1 ring-slate-200/80">
						<div class="text-[11px] font-extrabold uppercase tracking-[0.12em] text-slate-500">创建时间</div>
						<div class="mt-2 text-sm font-semibold text-slate-900">{ formatTime(data.Thread.CreatedAt) }</div>
					</div>
					<div class="rounded-[1.15rem] bg-slate-50/90 px-4 py-4 ring-1 ring-slate-200/80">
						<div class="text-[11px] font-extrabold uppercase tracking-[0.12em] text-slate-500">最近更新</div>
						<div class="mt-2 text-sm font-semibold text-slate-900">{ formatTime(data.Thread.UpdatedAt) }</div>
					</div>
				</div>
				<div class="rounded-[1.3rem] bg-slate-50/90 p-4 ring-1 ring-slate-200/80">
					<div class="text-xs font-extrabold uppercase tracking-[0.12em] text-slate-500">最近摘要变化</div>
					if len(topicSummaryHistory(data.Thread)) == 0 {
						<div class="mt-3 text-sm text-slate-500">还没有摘要快照。</div>
					} else {
						<div class="mt-3 space-y-3">
							for _, snapshot := range topicSummaryHistory(data.Thread) {
								<div class="rounded-[1.1rem] bg-white/84 p-4 ring-1 ring-slate-200/80">
									<div class="text-xs font-semibold uppercase tracking-[0.08em] text-slate-500">{ snapshot.CapturedAt }</div>
									<div class="mt-2 text-sm font-semibold text-slate-900">{ snapshot.Summary.Title }</div>
									<div class="mt-1 text-sm leading-6 text-slate-600">{ snapshot.Summary.Gist }</div>
								</div>
							}
						</div>
					}
				</div>
			</section>
		</div>
		<section class="space-y-4 rounded-[1.7rem] border border-white/70 bg-white/82 p-5 shadow-[0_22px_60px_rgba(14,31,53,0.08)] backdrop-blur-xl motion-safe:animate-[admin-fade-up_220ms_ease-out]">
			<div class="flex items-center justify-between gap-4">
				<div>
					<div class="text-sm font-extrabold tracking-[-0.02em] text-slate-900">关联消息</div>
					<div class="mt-1 text-sm leading-6 text-slate-500">最近 80 条与这个话题相关的消息，按时间顺序展示。</div>
				</div>
			</div>
			if len(data.Messages) == 0 {
				<div class="rounded-[1.75rem] border border-dashed border-slate-300/80 bg-white/55 p-6 text-center text-sm font-medium text-slate-500">暂无关联消息</div>
			} else {
				<div class="space-y-3">
					for _, item := range data.Messages {
						<article class="rounded-[1.25rem] border border-slate-200/75 bg-white/80 p-4 shadow-[inset_0_1px_0_rgba(255,255,255,0.82)]">
							<div class="flex flex-wrap items-center justify-between gap-3">
								<div class="text-sm font-semibold text-slate-900">{ item.Nickname }</div>
								<div class="text-xs font-semibold uppercase tracking-[0.08em] text-slate-500">{ formatTime(item.CreatedAt) } · #{ fmt.Sprintf("%d", item.ID) }</div>
							</div>
							<div class="mt-3 text-sm leading-7 text-slate-700 whitespace-pre-wrap break-words">{ topicMessageText(item) }</div>
						</article>
					}
				</div>
			}
		</section>
	</div>
}
