package views

import "fmt"

templ DashboardPage(data DashboardPageData, currentPath string) {
	@Layout(LayoutData{
		Title:       "统计看板",
		CurrentPath: currentPath,
		NavItems:    NavItems(),
		Flash:       data.Flash,
	}, DashboardBody(data))
}

templ DashboardBody(data DashboardPageData) {
	<div class="space-y-6">
		@PageHeader("统计看板", "查看运行状态、核心数据和系统概况。", "运行总览")
		<section class="rounded-[1.8rem] border border-white/70 bg-white/82 p-5 shadow-[0_22px_60px_rgba(14,31,53,0.08)] backdrop-blur-xl motion-safe:animate-[admin-fade-up_220ms_ease-out] sm:p-6">
			<div class="flex flex-wrap items-center gap-2">
				<div class="inline-flex items-center rounded-full bg-slate-950/5 px-3 py-1 text-[11px] font-extrabold uppercase tracking-[0.14em] text-slate-500">MumuBot / 数据摘要</div>
				<div class="inline-flex items-center rounded-full bg-cyan-50 px-3 py-1 text-[11px] font-bold tracking-[0.08em] text-cyan-700 ring-1 ring-cyan-200/80">已启用 { fmt.Sprintf("%d", data.EnabledGroupCount) } 个群</div>
			</div>
			<div class="mt-5 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
				<div class="space-y-3">
					<h2 class="text-balance text-[2.1rem] font-extrabold leading-none tracking-[-0.05em] text-slate-950 sm:text-[2.45rem]">{ data.BotName }</h2>
					<p class="max-w-2xl text-sm leading-6 text-slate-600">查看连接状态、启用群数和核心数据变化。</p>
				</div>
				<div class="rounded-[1.25rem] bg-slate-50/90 px-4 py-3 ring-1 ring-slate-200/80">
					<div class="text-[11px] font-extrabold uppercase tracking-[0.14em] text-slate-500">机器人 QQ</div>
					<div class="mt-1 text-lg font-bold tracking-[-0.03em] text-slate-950">{ fmt.Sprintf("%d", data.SelfID) }</div>
				</div>
			</div>
			<div class="mt-6 grid gap-4 xl:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)] xl:items-start">
				<section class="rounded-[1.45rem] border border-slate-200/80 bg-white/84 p-4 shadow-[inset_0_1px_0_rgba(255,255,255,0.85)]">
					<div class="flex items-center gap-2 text-sm font-extrabold tracking-[-0.02em] text-slate-900">
						<span class="inline-flex size-8 items-center justify-center rounded-full bg-slate-950/5 text-slate-500">
							@AdminIcon("runtime-summary", "size-4", "dashboard-runtime-summary")
						</span>
						<span>运行状态</span>
					</div>
					<div class="mt-4 grid gap-3 sm:grid-cols-2">
						<div class="rounded-[1.2rem] bg-slate-50/90 px-4 py-3.5 ring-1 ring-slate-200/80">
							<div class="flex items-center gap-2 text-[11px] font-extrabold uppercase tracking-[0.14em] text-slate-500">
								@AdminIcon("connection", "size-3.5", "dashboard-connection")
								<span>连接状态</span>
							</div>
							<div class="mt-2 text-base font-semibold text-slate-900">{ connectionText(data.OneBotConnected) }</div>
						</div>
						<div class="rounded-[1.2rem] bg-slate-50/90 px-4 py-3.5 ring-1 ring-slate-200/80">
							<div class="flex items-center gap-2 text-[11px] font-extrabold uppercase tracking-[0.14em] text-slate-500">
								@AdminIcon("learning", "size-3.5", "dashboard-learning")
								<span>学习状态</span>
							</div>
							<div class="mt-2 text-base font-semibold text-slate-900">{ boolText(data.LearningEnabled) }</div>
						</div>
						<div class="rounded-[1.2rem] bg-slate-50/90 px-4 py-3.5 ring-1 ring-slate-200/80">
							<div class="flex items-center gap-2 text-[11px] font-extrabold uppercase tracking-[0.14em] text-slate-500">
								@AdminIcon("groups", "size-3.5", "dashboard-groups")
								<span>启用群数</span>
							</div>
							<div class="mt-2 text-base font-semibold text-slate-900">{ fmt.Sprintf("%d 个", data.EnabledGroupCount) }</div>
						</div>
						<div class="rounded-[1.2rem] bg-slate-50/90 px-4 py-3.5 ring-1 ring-slate-200/80">
							<div class="flex items-center gap-2 text-[11px] font-extrabold uppercase tracking-[0.14em] text-slate-500">
								@AdminIcon("tools", "size-3.5", "dashboard-tools")
								<span>扩展工具</span>
							</div>
							<div class="mt-2 text-base font-semibold text-slate-900">{ fmt.Sprintf("%d 个", data.MCPToolCount) }</div>
						</div>
					</div>
				</section>
				<section class="rounded-[1.45rem] border border-slate-200/80 bg-white/84 p-4 shadow-[inset_0_1px_0_rgba(255,255,255,0.85)]">
					<div class="flex items-center gap-2 text-sm font-extrabold tracking-[-0.02em] text-slate-900">
						<span class="inline-flex size-8 items-center justify-center rounded-full bg-slate-950/5 text-slate-500">
							@AdminIcon("overview", "size-4", "dashboard-data-summary")
						</span>
						<span>核心数据</span>
					</div>
					<div class="mt-4 grid gap-3 sm:grid-cols-2 xl:grid-cols-3">
						<div class="rounded-[1.2rem] bg-slate-50/90 px-4 py-3.5 ring-1 ring-slate-200/80">
							<div class="flex items-center gap-2 text-[11px] font-extrabold uppercase tracking-[0.14em] text-slate-500">
								@AdminIcon("memories", "size-3.5", "dashboard-memory-count")
								<span>记忆数</span>
							</div>
							<div class="mt-2 text-base font-semibold text-slate-900">{ fmt.Sprintf("%d", data.MemoryCount) }</div>
						</div>
						<div class="rounded-[1.2rem] bg-slate-50/90 px-4 py-3.5 ring-1 ring-slate-200/80">
							<div class="flex items-center gap-2 text-[11px] font-extrabold uppercase tracking-[0.14em] text-slate-500">
								@AdminIcon("members", "size-3.5", "dashboard-member-count")
								<span>成员数</span>
							</div>
							<div class="mt-2 text-base font-semibold text-slate-900">{ fmt.Sprintf("%d", data.MemberCount) }</div>
						</div>
						<div class="rounded-[1.2rem] bg-slate-50/90 px-4 py-3.5 ring-1 ring-slate-200/80">
							<div class="flex items-center gap-2 text-[11px] font-extrabold uppercase tracking-[0.14em] text-slate-500">
								@AdminIcon("jargons", "size-3.5", "dashboard-jargon-count")
								<span>黑话数</span>
							</div>
							<div class="mt-2 text-base font-semibold text-slate-900">{ fmt.Sprintf("%d", data.JargonCount) }</div>
						</div>
						<div class="rounded-[1.2rem] bg-slate-50/90 px-4 py-3.5 ring-1 ring-slate-200/80">
							<div class="flex items-center gap-2 text-[11px] font-extrabold uppercase tracking-[0.14em] text-slate-500">
								@AdminIcon("style-cards", "size-3.5", "dashboard-style-card-count")
								<span>风格卡片数</span>
							</div>
							<div class="mt-2 text-base font-semibold text-slate-900">{ fmt.Sprintf("%d", data.StyleCardCount) }</div>
						</div>
						<div class="rounded-[1.2rem] bg-slate-50/90 px-4 py-3.5 ring-1 ring-slate-200/80">
							<div class="flex items-center gap-2 text-[11px] font-extrabold uppercase tracking-[0.14em] text-slate-500">
								@AdminIcon("stickers", "size-3.5", "dashboard-sticker-count")
								<span>表情包数</span>
							</div>
							<div class="mt-2 text-base font-semibold text-slate-900">{ fmt.Sprintf("%d", data.StickerCount) }</div>
						</div>
					</div>
				</section>
			</div>
			if data.CurrentMood != nil {
				<section class="mt-4 rounded-[1.45rem] border border-cyan-100 bg-cyan-50/70 p-4 shadow-[inset_0_1px_0_rgba(255,255,255,0.7)]">
					<div class="flex items-center gap-2 text-sm font-extrabold tracking-[-0.02em] text-cyan-800">
						<span class="inline-flex size-8 items-center justify-center rounded-full bg-white/60 text-cyan-700 ring-1 ring-cyan-100/90">
							@AdminIcon("mood", "size-4", "dashboard-mood")
						</span>
						<span>当前情绪</span>
					</div>
					<div class="mt-4 grid gap-3 lg:grid-cols-[repeat(3,minmax(0,1fr))_minmax(0,1.4fr)]">
						<div class="rounded-[1.15rem] bg-white/72 px-4 py-3.5 ring-1 ring-cyan-100/90">
							<div class="text-[11px] font-extrabold uppercase tracking-[0.14em] text-cyan-700/80">心情</div>
							<div class="mt-2 text-base font-semibold text-slate-900">{ fmt.Sprintf("%.2f", data.CurrentMood.Valence) }</div>
						</div>
						<div class="rounded-[1.15rem] bg-white/72 px-4 py-3.5 ring-1 ring-cyan-100/90">
							<div class="text-[11px] font-extrabold uppercase tracking-[0.14em] text-cyan-700/80">精力</div>
							<div class="mt-2 text-base font-semibold text-slate-900">{ fmt.Sprintf("%.2f", data.CurrentMood.Energy) }</div>
						</div>
						<div class="rounded-[1.15rem] bg-white/72 px-4 py-3.5 ring-1 ring-cyan-100/90">
							<div class="text-[11px] font-extrabold uppercase tracking-[0.14em] text-cyan-700/80">社交意愿</div>
							<div class="mt-2 text-base font-semibold text-slate-900">{ fmt.Sprintf("%.2f", data.CurrentMood.Sociability) }</div>
						</div>
						<div class="rounded-[1.15rem] bg-white/72 px-4 py-3.5 ring-1 ring-cyan-100/90">
							<div class="text-[11px] font-extrabold uppercase tracking-[0.14em] text-cyan-700/80">最近原因</div>
							<div class="mt-2 text-sm leading-6 text-slate-700">{ emptyDash(data.CurrentMood.LastReason) }</div>
						</div>
					</div>
				</section>
			}
		</section>
	</div>
}
